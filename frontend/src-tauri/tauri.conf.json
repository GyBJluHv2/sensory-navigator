{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Сенсорный навигатор",
  "version": "1.0.0",
  "identifier": "ru.hse.sensorynavigator",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Сенсорный навигатор",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "Карта с отзывами для людей, склонных к сенсорной перегрузке",
    "longDescription": "Сенсорный навигатор — кроссплатформенный десктопный сервис, помогающий людям с расстройством аутистического спектра и повышенной сенсорной чувствительностью находить комфортные общественные места и совместно наполнять базу отзывов о них."
  }
}
